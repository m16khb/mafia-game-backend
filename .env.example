# 환경
NODE_ENV='local'

# 서버 설정
PORT=3000
FRONTEND_URL='http://localhost:3001'

# 데이터베이스 설정 (MySQL)
DB_HOST='localhost'
DB_PORT=3306
DB_USERNAME='mafia_user'
DB_PASSWORD='mafia_pass123'
DB_DATABASE='mafia_game'

# Redis 설정
REDIS_HOST='localhost'
REDIS_PORT=6379

# JWT 설정
JWT_SECRET='your-super-secret-jwt-key-change-in-production'

# 게임 설정
DEFAULT_GAME_TIMEOUT=300

# NPM 패키지 버전
NPM_PACKAGE_VERSION='1.0.0'

# OpenRouter Configuration (AI Integration)
OPENROUTER_API_KEY='your_openrouter_api_key_here'
OPENROUTER_MODEL_ROUTINE='anthropic/claude-3-haiku'
OPENROUTER_MODEL_STRATEGY='openai/gpt-4-turbo'
OPENROUTER_DAILY_LIMIT=10.00

# AI Configuration
AI_DECISION_TIMEOUT=30000
AI_CONCURRENT_LIMIT=5
AI_MAX_QUEUE_SIZE=50
AI_RETRY_ATTEMPTS=3
AI_RETRY_DELAY_MS=1000
AI_CACHE_TTL=30
AI_CACHE_MAX_SIZE=104857600
AI_CACHE_COMPRESSION=true
AI_DEFAULT_PERSONALITY_SET='default'